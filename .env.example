# Form Góp ý Tally (nút Feedback) — dán link Publish từ Tally, ví dụ https://tally.so/r/AbCdEf
FEEDBACK_TALLY_URL=https://tally.so/r/your-form-id

RAPIDAPI_KEY=your_rapidapi_key_here
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/smartchoice?appName=Cluster0
# site_stats.page_views — bộ đếm GET /api/pageviews (tự tạo document _id: "page_views")
# Mốc khởi đầu hiển thị (mặc định 125), mỗi lượt tải trang +1
PAGE_VIEWS_BASELINE=125
API_CACHE_TTL_MINUTES=360
