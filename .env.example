# Copy this file to `.env` and fill in your own values.
# Never commit `.env` to Git.

# --- Required for live supermarket search (RapidAPI) ---
RAPIDAPI_KEY=

# --- Required for AI shopping-list analysis ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Required for MongoDB cache, price history, pageviews ---
MONGODB_URI=

# --- Coles mobile barcode/name lookup (optional; used for direct Coles API) ---
COLES_API_KEY=
COLES_API_SECRET=

# --- Optional ---
PORT=3000
FEEDBACK_TALLY_URL=
API_CACHE_TTL_MINUTES=360
# MATCH_DEBUG=1
